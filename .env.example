# XSafeClaw Configuration
# Leave DATABASE_URL empty to use default: ~/.xsafeclaw/data.db
# DATABASE_URL=sqlite+aiosqlite:///path/to/custom.db

# OpenClaw Sessions Directory
OPENCLAW_SESSIONS_DIR=~/.openclaw/agents/main/sessions

# API Configuration
API_HOST=0.0.0.0
API_PORT=6874

# Logging
LOG_LEVEL=INFO

# File Watcher
ENABLE_FILE_WATCHER=true
WATCH_INTERVAL_SECONDS=1
