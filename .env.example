# XSafeClaw Configuration
# Copy this file to .env when you need to override defaults.

# Data and Database
# Leave DATABASE_URL empty to use default: ~/.xsafeclaw/data.db
DATA_DIR=~/.xsafeclaw
# DATABASE_URL=sqlite+aiosqlite:///path/to/custom.db

# Runtime: OpenClaw
OPENCLAW_SESSIONS_DIR=~/.openclaw/agents/main/sessions

# Runtime: Hermes
# XSafeClaw talks to Hermes through the local HTTP API exposed by `hermes gateway`.
HERMES_HOME=~/.hermes
HERMES_SESSIONS_DIR=~/.hermes/sessions
HERMES_CONFIG_PATH=~/.hermes/config.yaml
HERMES_API_PORT=8642
# Must match API_SERVER_KEY in ~/.hermes/.env. The Configure UI can generate
# and sync this value for you.
# HERMES_API_KEY=

# Runtime: nanobot
# nanobot is configured in ~/.nanobot/config.json, not through .env.
# XSafeClaw copies plugins/safeclaw-guard-nanobot to ~/.nanobot/plugins/safeclaw-guard
# and injects SAFETY.md / PERMISSION.md through the configured hook.
# Development install:
#   uv tool install nanobot-ai --with-editable . --force
# Manual troubleshooting gateway:
#   nanobot gateway --port 18790 --verbose
# XSafeClaw writes gateway + hook settings through the Nanobot Configure page
# or, for legacy callers:
#   POST /api/system/nanobot/init-default

# API Configuration
API_HOST=0.0.0.0
API_PORT=6874
API_RELOAD=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:3003","http://localhost:5173","http://localhost:6874"]

# Runtime default-instance hint (auto | openclaw | hermes | nanobot).
# This only picks the default runtime shown first; all discovered runtimes
# remain selectable in Agent Town.
# PLATFORM=auto

# Best-effort auto-start for installed OpenClaw / Hermes / nanobot gateways.
# Set AUTO_START_RUNTIMES=false to keep the legacy manual-start workflow.
AUTO_START_RUNTIMES=true

# Logging
LOG_LEVEL=INFO

# File Watcher
ENABLE_FILE_WATCHER=true
WATCH_INTERVAL_SECONDS=1

# Sync Service
FULL_SCAN_INTERVAL_HOURS=1
BATCH_SIZE=100

# Guard Model (AgentDoG)
GUARD_BASE_URL=http://localhost:8822/v1
GUARD_BASE_MODEL=AgentDoG-Qwen3-4B
GUARD_FG_URL=http://localhost:8823/v1
GUARD_FG_MODEL=AgentDoG-FG-Qwen3-4B
GUARD_API_KEY=EMPTY
GUARD_TIMEOUT=120
