{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XSafeClaw",
  "version": "0.1.0",
  "identifier": "ai.xsafeclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 3003",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:3003",
    "frontendDist": "../../src/xsafeclaw/static"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XSafeClaw",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 650,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "XSafeClaw",
    "shortDescription": "XSafeClaw desktop app",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
