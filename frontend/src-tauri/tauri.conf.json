{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XSafeClaw",
  "version": "0.1.0",
  "identifier": "ai.xsafeclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 3003",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:3003",
    "frontendDist": "../../src/xsafeclaw/static"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "XSafeClaw",
    "shortDescription": "XSafeClaw desktop app",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/xsafeclaw-backend"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
