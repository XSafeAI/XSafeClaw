.intro-screen {
  position: fixed;
  inset: 0;
  z-index: 9999;
  overflow: hidden;
  background: #4e93c7;
  isolation: isolate;
}

.intro-screen--exit {
  animation: intro-screen-out 960ms ease forwards;
  pointer-events: none;
}

.intro-screen__scene,
.intro-screen__content,
.intro-screen__sky-light,
.intro-screen__light-rays,
.intro-screen__lower-shade,
.intro-screen__vignette {
  position: absolute;
  inset: 0;
}

.intro-screen__backdrop,
.intro-screen__cloud,
.intro-screen__friends,
.intro-screen__logo {
  user-select: none;
  -webkit-user-drag: none;
}

.intro-screen__backdrop {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  image-rendering: pixelated;
  opacity: 0;
  transform: scale(1.015);
  animation: intro-backdrop-settle 620ms cubic-bezier(0.16, 0.8, 0.22, 1) forwards;
}

.intro-screen__sky-light {
  z-index: 2;
  opacity: 0;
  background:
    radial-gradient(circle at 55% 22%, rgba(255, 250, 214, 0.34) 0%, rgba(255, 250, 214, 0.18) 18%, rgba(255, 250, 214, 0.06) 34%, transparent 58%),
    radial-gradient(circle at 52% 36%, rgba(255, 243, 204, 0.14) 0%, transparent 42%);
  animation: intro-fade-in 760ms ease 120ms forwards;
}

.intro-screen__light-rays {
  z-index: 3;
  opacity: 0;
  background:
    linear-gradient(110deg, transparent 18%, rgba(255, 255, 255, 0.16) 34%, transparent 48%),
    linear-gradient(72deg, transparent 40%, rgba(255, 248, 220, 0.1) 54%, transparent 70%);
  transform: scale(1.08) translateY(-2%);
  transform-origin: center top;
  animation: intro-light-rays 1.2s ease 220ms forwards;
}

.intro-screen__lower-shade {
  z-index: 4;
  opacity: 0;
  background:
    linear-gradient(180deg, transparent 48%, rgba(8, 12, 20, 0.08) 62%, rgba(6, 10, 18, 0.24) 76%, rgba(5, 9, 16, 0.5) 100%),
    radial-gradient(ellipse at 78% 100%, rgba(4, 8, 16, 0.5) 0%, rgba(4, 8, 16, 0.24) 30%, transparent 64%);
  animation: intro-lower-shade 900ms ease 480ms forwards;
}

.intro-screen__cloud {
  position: absolute;
  object-fit: contain;
  image-rendering: pixelated;
  opacity: 0;
  pointer-events: none;
  mix-blend-mode: screen;
  animation-name: intro-cloud-in, intro-cloud-drift;
  animation-duration: 820ms, var(--cloud-loop-duration, 14s);
  animation-timing-function: cubic-bezier(0.16, 0.8, 0.22, 1), ease-in-out;
  animation-delay: var(--cloud-enter-delay, 0s), calc(var(--cloud-enter-delay, 0s) + 1.1s);
  animation-fill-mode: forwards, none;
  animation-iteration-count: 1, infinite;
  animation-direction: normal, alternate;
  transform: translate3d(var(--cloud-start-x, 0), var(--cloud-start-y, 0), 0) scale(var(--cloud-scale, 1));
}

.intro-screen__cloud--bottom-left-back {
  left: -10vw;
  bottom: clamp(-6px, 0.5vh, 8px);
  z-index: 10;
  width: min(34vw, 520px);
  --cloud-start-x: -1.4vw;
  --cloud-start-y: 3.4vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.46;
  --cloud-enter-delay: 0.58s;
  --cloud-drift-x: 0.9vw;
  --cloud-drift-y: 0.4vh;
  --cloud-loop-duration: 12s;
}

.intro-screen__cloud--bottom-left-soft {
  left: 14vw;
  bottom: clamp(82px, 13vh, 150px);
  z-index: 11;
  width: min(12vw, 180px);
  --cloud-start-x: -0.8vw;
  --cloud-start-y: 2.6vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.34;
  --cloud-enter-delay: 0.72s;
  --cloud-drift-x: 0.7vw;
  --cloud-drift-y: 0.35vh;
  --cloud-loop-duration: 13.5s;
}

.intro-screen__cloud--bottom-left-front {
  left: -4vw;
  bottom: clamp(14px, 3vh, 38px);
  z-index: 12;
  width: min(28vw, 420px);
  --cloud-start-x: -0.8vw;
  --cloud-start-y: 3vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.6;
  --cloud-enter-delay: 0.86s;
  --cloud-drift-x: 0.8vw;
  --cloud-drift-y: 0.4vh;
  --cloud-loop-duration: 11.8s;
}

.intro-screen__cloud--bottom-mid-back {
  left: 27vw;
  bottom: clamp(-8px, 0.4vh, 10px);
  z-index: 10;
  width: min(30vw, 460px);
  --cloud-start-x: 0.6vw;
  --cloud-start-y: 2.8vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.42;
  --cloud-enter-delay: 0.94s;
  --cloud-drift-x: 0.7vw;
  --cloud-drift-y: 0.35vh;
  --cloud-loop-duration: 12.8s;
}

.intro-screen__cloud--bottom-mid-front {
  left: 46vw;
  bottom: clamp(0px, 1vh, 18px);
  z-index: 13;
  width: min(22vw, 340px);
  --cloud-start-x: 0.9vw;
  --cloud-start-y: 2.8vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.5;
  --cloud-enter-delay: 1.02s;
  --cloud-drift-x: 0.65vw;
  --cloud-drift-y: 0.3vh;
  --cloud-loop-duration: 11.5s;
}

.intro-screen__cloud--bottom-right-soft {
  left: 68vw;
  bottom: clamp(58px, 10vh, 120px);
  z-index: 14;
  width: min(10vw, 150px);
  --cloud-start-x: 0.4vw;
  --cloud-start-y: 2.1vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.26;
  --cloud-enter-delay: 1.08s;
  --cloud-drift-x: 0.45vw;
  --cloud-drift-y: 0.26vh;
  --cloud-loop-duration: 13.6s;
}

.intro-screen__cloud--bottom-right-back {
  left: 72vw;
  bottom: clamp(6px, 1.2vh, 18px);
  z-index: 15;
  width: min(18vw, 260px);
  --cloud-start-x: 0.5vw;
  --cloud-start-y: 2.8vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.36;
  --cloud-enter-delay: 1.12s;
  --cloud-drift-x: 0.5vw;
  --cloud-drift-y: 0.28vh;
  --cloud-loop-duration: 12.2s;
}

.intro-screen__cloud--bottom-right-under {
  left: 80vw;
  bottom: clamp(-2px, 0.2vh, 10px);
  z-index: 16;
  width: min(16vw, 240px);
  --cloud-start-x: 0.35vw;
  --cloud-start-y: 2.4vh;
  --cloud-end-y: 0vh;
  --cloud-opacity: 0.28;
  --cloud-enter-delay: 1.2s;
  --cloud-drift-x: 0.35vw;
  --cloud-drift-y: 0.22vh;
  --cloud-loop-duration: 12.8s;
}

.intro-screen__friends-shell {
  position: absolute;
  right: -2px;
  left: auto;
  bottom: -2px;
  z-index: 24;
  width: auto;
  height: clamp(176px, 22.5vh, 243px);
  aspect-ratio: 1927 / 511;
  opacity: 0;
  pointer-events: none;
  transform: translate3d(0, 8vh, 0) scale(0.96);
  transform-origin: right bottom;
  animation: intro-friends-rise 920ms cubic-bezier(0.16, 0.8, 0.22, 1) 620ms forwards;
}

.intro-screen__friends-glow {
  position: absolute;
  inset: -12% -6% -2% 18%;
  z-index: 0;
  opacity: 0;
  background:
    radial-gradient(ellipse at 66% 58%, rgba(255, 237, 182, 0.28) 0%, rgba(255, 237, 182, 0.1) 34%, transparent 68%),
    radial-gradient(ellipse at 62% 60%, rgba(255, 255, 255, 0.1) 0%, transparent 56%);
  transform: scale(0.95);
  animation: intro-friends-glow 820ms ease 760ms forwards;
}

.intro-screen__friends {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  object-fit: contain;
  image-rendering: pixelated;
  filter:
    drop-shadow(1px 0 0 rgba(7, 10, 14, 0.92))
    drop-shadow(-1px 0 0 rgba(7, 10, 14, 0.92))
    drop-shadow(0 1px 0 rgba(7, 10, 14, 0.92))
    drop-shadow(0 -1px 0 rgba(7, 10, 14, 0.92))
    drop-shadow(0 16px 22px rgba(9, 15, 24, 0.22));
}

.intro-screen__friends--frame-a {
  opacity: 1;
}

.intro-screen__friends--frame-b {
  opacity: 0;
  animation: intro-friends-frame-b 1.8s steps(1, end) 1.7s infinite;
}

.intro-screen__vignette {
  z-index: 18;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, transparent 26%, rgba(5, 11, 23, 0.1) 72%, rgba(5, 11, 23, 0.28) 100%),
    radial-gradient(circle at center, transparent 50%, rgba(8, 14, 24, 0.08) 76%, rgba(8, 14, 24, 0.2) 100%);
}

.intro-screen__content {
  z-index: 26;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 2rem;
  padding-top: clamp(3.25rem, 11vh, 6.5rem);
}

.intro-screen__logo {
  width: min(66vw, 720px);
  max-width: 100%;
  opacity: 0;
  transform: translate3d(0, -8vh, 0) scale(0.92);
  filter: drop-shadow(0 18px 24px rgba(22, 33, 48, 0.24));
  animation: intro-logo-drop 860ms cubic-bezier(0.16, 0.8, 0.22, 1) 260ms forwards;
}

@keyframes intro-backdrop-settle {
  0% {
    opacity: 0;
    transform: scale(1.02);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes intro-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes intro-light-rays {
  0% {
    opacity: 0;
    transform: scale(1.08) translateY(-2%);
  }
  100% {
    opacity: 0.85;
    transform: scale(1) translateY(0);
  }
}

@keyframes intro-lower-shade {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes intro-cloud-in {
  0% {
    opacity: 0;
    transform: translate3d(var(--cloud-start-x, 0), var(--cloud-start-y, 0), 0) scale(var(--cloud-scale, 1));
  }
  100% {
    opacity: var(--cloud-opacity, 0.6);
    transform: translate3d(var(--cloud-end-x, 0), var(--cloud-end-y, 0), 0) scale(var(--cloud-scale, 1));
  }
}

@keyframes intro-cloud-drift {
  0% {
    transform: translate3d(var(--cloud-end-x, 0), var(--cloud-end-y, 0), 0) scale(var(--cloud-scale, 1));
  }
  100% {
    transform: translate3d(
      calc(var(--cloud-end-x, 0) + var(--cloud-drift-x, 0)),
      calc(var(--cloud-end-y, 0) + var(--cloud-drift-y, 0)),
      0
    ) scale(var(--cloud-drift-scale, var(--cloud-scale, 1)));
  }
}

@keyframes intro-logo-drop {
  0% {
    opacity: 0;
    transform: translate3d(0, -8vh, 0) scale(0.92);
  }
  68% {
    opacity: 1;
    transform: translate3d(0, 0.8vh, 0) scale(1.01);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes intro-friends-rise {
  0% {
    opacity: 0;
    transform: translate3d(0, 8vh, 0) scale(0.96);
  }
  72% {
    opacity: 1;
    transform: translate3d(0, -0.5vh, 0) scale(1.004);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes intro-friends-glow {
  0% {
    opacity: 0;
    transform: scale(0.95);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes intro-friends-frame-b {
  0%,
  44% {
    opacity: 0;
  }
  45%,
  89% {
    opacity: 1;
  }
  90%,
  100% {
    opacity: 0;
  }
}

@keyframes intro-screen-out {
  from {
    opacity: 1;
    transform: scale(1);
  }
  to {
    opacity: 0;
    transform: scale(1.012);
  }
}

@media (max-width: 900px) {
  .intro-screen__content {
    padding-top: clamp(2.5rem, 8vh, 4.5rem);
  }

  .intro-screen__logo {
    width: min(84vw, 620px);
  }

  .intro-screen__friends-shell {
    right: -1px;
    bottom: -1px;
    height: clamp(118px, 17vh, 152px);
  }

  .intro-screen__cloud--bottom-left-back {
    left: -18vw;
    width: min(34vw, 250px);
  }

  .intro-screen__cloud--bottom-left-soft {
    left: 14vw;
    bottom: clamp(44px, 10vh, 84px);
    width: min(12vw, 90px);
  }

  .intro-screen__cloud--bottom-left-front {
    left: -8vw;
    width: min(26vw, 180px);
  }

  .intro-screen__cloud--bottom-mid-back {
    left: 22vw;
    width: min(24vw, 180px);
  }

  .intro-screen__cloud--bottom-mid-front {
    left: 40vw;
    width: min(19vw, 130px);
  }

  .intro-screen__cloud--bottom-right-soft {
    left: 64vw;
    bottom: clamp(30px, 8vh, 56px);
    width: min(9vw, 60px);
  }

  .intro-screen__cloud--bottom-right-back {
    left: 70vw;
    width: min(16vw, 110px);
  }

  .intro-screen__cloud--bottom-right-under {
    left: 78vw;
    width: min(14vw, 96px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .intro-screen--exit,
  .intro-screen__backdrop,
  .intro-screen__sky-light,
  .intro-screen__light-rays,
  .intro-screen__lower-shade,
  .intro-screen__cloud,
  .intro-screen__friends-shell,
  .intro-screen__friends-glow,
  .intro-screen__friends--frame-b,
  .intro-screen__logo {
    animation: none !important;
  }

  .intro-screen__backdrop {
    opacity: 1;
    transform: scale(1);
  }

  .intro-screen__sky-light {
    opacity: 1;
  }

  .intro-screen__light-rays {
    opacity: 0.55;
    transform: none;
  }

  .intro-screen__lower-shade {
    opacity: 1;
  }

  .intro-screen__cloud {
    opacity: var(--cloud-opacity, 0.6);
    transform: translate3d(var(--cloud-end-x, 0), var(--cloud-end-y, 0), 0) scale(var(--cloud-scale, 1));
  }

  .intro-screen__friends-shell {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .intro-screen__friends-glow {
    opacity: 1;
    transform: scale(1);
  }

  .intro-screen__friends--frame-b {
    opacity: 0;
  }

  .intro-screen__logo {
    opacity: 1;
    transform: none;
  }
}
